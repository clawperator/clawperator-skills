{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawperator.dev/schemas/skills-registry.schema.json",
  "title": "Skills Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "skills"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "applicationId",
          "intent",
          "summary",
          "path",
          "skillFile",
          "scripts",
          "artifacts"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9._-]+$"
          },
          "applicationId": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9._]+$"
          },
          "intent": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "keywords": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "path": {
            "type": "string",
            "pattern": "^skills/[a-zA-Z0-9._-]+$"
          },
          "skillFile": {
            "type": "string",
            "pattern": "^skills/[a-zA-Z0-9._-]+/SKILL\\.md$"
          },
          "scripts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^skills/[a-zA-Z0-9._-]+/scripts/[a-zA-Z0-9._-]+\\.(sh|js)$"
            }
          },
          "agent": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "cli"
            ],
            "properties": {
              "cli": {
                "type": "string",
                "minLength": 1
              },
              "cliPath": {
                "oneOf": [
                  {
                    "type": "string",
                    "minLength": 1
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "timeoutMs": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "inputs",
              "goal",
              "verification"
            ],
            "properties": {
              "inputs": {
                "type": "object",
                "additionalProperties": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "goal": {
                "oneOf": [
                  {
                    "type": "null"
                  },
                  {
                    "type": "object",
                    "required": [
                      "kind"
                    ],
                    "properties": {
                      "kind": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "additionalProperties": true
                  }
                ]
              },
              "verification": {
                "oneOf": [
                  {
                    "type": "null"
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "kind",
                      "matcher"
                    ],
                    "properties": {
                      "kind": {
                        "const": "node_text_matches"
                      },
                      "matcher": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  }
                ]
              }
            }
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^skills/[a-zA-Z0-9._-]+/artifacts/[a-zA-Z0-9._-]+\\.(recipe\\.json|md|json)$"
            }
          }
        }
      }
    }
  }
}
